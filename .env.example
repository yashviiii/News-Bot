# News Ingestion Pipeline configuration.
# Copy to .env. No edits required for default operation.

# Path to SQLite database file (relative to repo root by default).
DB_PATH=news.db

# Optional: override the embedding model name. Defaults to BAAI/bge-small-en-v1.5.
# EMBED_MODEL_NAME=BAAI/bge-small-en-v1.5

# Optional: override HTTP user agent used when fetching articles.
# USER_AGENT=NewsIngestionPipeline/0.1 (research project)

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
# LOG_LEVEL=INFO
