# ---------------------------------------------------------------------------
# Python bytecode + caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Packaging / build artifacts
# ---------------------------------------------------------------------------
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Test + coverage artifacts
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.cache/

# ---------------------------------------------------------------------------
# Local secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
# .env.example IS tracked — it's the template.

# ---------------------------------------------------------------------------
# Runtime SQLite databases
#   - sample.db is the committed pre-populated demo DB (kept).
#   - news.db (and any other *.db) is created on first run; ignore it.
#   - SQLite WAL / SHM sidecars are always transient.
# ---------------------------------------------------------------------------
*.db
!sample.db
*.db-shm
*.db-wal
*.db-journal

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs + temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig

# ---------------------------------------------------------------------------
# Hugging Face / model caches accidentally placed in the project tree
# (the canonical cache lives in ~/.cache/huggingface/ outside the repo)
# ---------------------------------------------------------------------------
.hf_cache/
huggingface_cache/
